# مصدر بيانات الأسعار: yahoo | alphavantage | twelvedata
DATA_SOURCE=yahoo

# مفتاح Alpha Vantage (مجاني: https://www.alphavantage.co/support/#api-key)
# حدود مجانية: 25 طلب/يوم، 5 طلب/دقيقة
# ALPHAVANTAGE_API_KEY=your_key_here

# مفتاح Twelve Data (مجاني: https://twelvedata.com/apikey)
# حدود مجانية: 8 نقاط/دقيقة، 800 نقطة/يوم
# TWELVEDATA_API_KEY=your_key_here
